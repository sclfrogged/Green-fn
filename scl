#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_ADDR 256

typedef struct {
    char address[MAX_ADDR];
    int rooms;
    float area;
    float rent;
} Apartment;

typedef struct {
    Apartment *data;
    int size;
} ApartmentArray;

/* Inicializaciya pustogo massiva */
void init_array(ApartmentArray *arr) {
    arr->data = NULL;
    arr->size = 0;
}

/* Rasshirenie massiva na count elementov
   BEZ realloc: vydelyaem novuyu oblast, kopiruyem, osvobozhdaem staruyu */
int expand_array(ApartmentArray *arr, int count) {
    if (count <= 0) return 0;

    int new_size = arr->size + count;
    Apartment *new_data = (Apartment *)malloc(new_size * sizeof(Apartment));
    if (!new_data) {
        printf("Oshibka: ne udalos vydelit pamyat!\n");
        return 0;
    }

    /* Kopiruyem starye dannye v novuyu oblast */
    for (int i = 0; i < arr->size; i++) {
        new_data[i] = arr->data[i];
    }

    /* Osvobozhdaem staruyu oblast pamyati */
    free(arr->data);

    arr->data = new_data;
    arr->size = new_size;
    return 1;
}

/* Dobavlenie novogo elementa v konec massiva */
int push_back(ApartmentArray *arr, Apartment apt) {
    /* Rasshiryaem massiv na 1 element */
    if (!expand_array(arr, 1)) return 0;

    /* Vstavlyaem v poslednyuyu poziciyu */
    arr->data[arr->size - 1] = apt;
    return 1;
}

/* Umenshenie massiva: udalenie poslednego elementa */
int pop_back(ApartmentArray *arr) {
    if (arr->size == 0) {
        printf("Massiv pust. Nechego udalyat.\n");
        return 0;
    }

    int new_size = arr->size - 1;

    if (new_size == 0) {
        free(arr->data);
        arr->data = NULL;
        arr->size = 0;
        printf("Posledniy element udalyon. Massiv teper pust.\n");
        return 1;
    }

    /* Vydelyaem novuyu oblast menshego razmera */
    Apartment *new_data = (Apartment *)malloc(new_size * sizeof(Apartment));
    if (!new_data) {
        printf("Oshibka: ne udalos vydelit pamyat!\n");
        return 0;
    }

    /* Kopiruyem vse krome poslednego */
    for (int i = 0; i < new_size; i++) {
        new_data[i] = arr->data[i];
    }

    /* Osvobozhdaem staruyu pamyat */
    free(arr->data);

    arr->data = new_data;
    arr->size = new_size;
    return 1;
}

/* Ruchnoe osvobozhdenie vsey pamyati i ochistka spiska */
void clear_array(ApartmentArray *arr) {
    if (arr->data != NULL) {
        free(arr->data);
        arr->data = NULL;
    }
    arr->size = 0;
    printf("Pamyat osvobozhdena. Spisok ochishchen.\n");
}

/* Vyvod odnoy kvartiry */
void print_apartment(const Apartment *apt, int index) {
    printf("--- Kvartira #%d ---\n", index + 1);
    printf("  Adres        : %s\n", apt->address);
    printf("  Komnat       : %d\n", apt->rooms);
    printf("  Ploshchad    : %.2f kv.m\n", apt->area);
    printf("  Stoimost     : %.2f rub./mes.\n", apt->rent);
}

/* Vyvod vsego massiva */
void print_all(const ApartmentArray *arr) {
    if (arr->size == 0) {
        printf("Spisok kvartir pust.\n");
        return;
    }
    printf("\n=== Spisok kvartir (%d sht.) ===\n", arr->size);
    for (int i = 0; i < arr->size; i++) {
        print_apartment(&arr->data[i], i);
    }
}

/* Vvod kvartiry s klaviatury */
Apartment input_apartment() {
    Apartment apt;

    printf("Vvedite adres: ");
    fgets(apt.address, MAX_ADDR, stdin);
    apt.address[strcspn(apt.address, "\n")] = '\0';

    printf("Vvedite kolichestvo komnat: ");
    scanf("%d", &apt.rooms);

    printf("Vvedite ploshchad (kv.m): ");
    scanf("%f", &apt.area);

    printf("Vvedite stoimost arendy (rub./mes.): ");
    scanf("%f", &apt.rent);

    /* Ochishchaem bufer posle scanf */
    while (getchar() != '\n');
    return apt;
}

void print_menu() {
    printf("\n========= MENYU =========\n");
    printf("1. Dobavit kvartiru v konec\n");
    printf("2. Udalit poslednyuyu kvartiru\n");
    printf("3. Rasshirit massiv (pustye sloty)\n");
    printf("4. Pokazat vse kvartiry\n");
    printf("5. Ochistit spisok i osvobodic pamyat\n");
    printf("0. Vyhod\n");
    printf("Vybor: ");
}

int main() {
    ApartmentArray arr;
    init_array(&arr);

    int choice;
    do {
        print_menu();
        scanf("%d", &choice);
        while (getchar() != '\n');

        switch (choice) {
            case 1: {
                Apartment apt = input_apartment();
                if (push_back(&arr, apt))
                    printf("Kvartira dobavlena. Razmer massiva: %d\n", arr.size);
                break;
            }
            case 2: {
                if (pop_back(&arr))
                    printf("Poslednyaya kvartira udalena. Razmer massiva: %d\n", arr.size);
                break;
            }
            case 3: {
                int count;
                printf("Na skolko elementov rasshirit massiv? ");
                scanf("%d", &count);
                while (getchar() != '\n');
                if (expand_array(&arr, count))
                    printf("Massiv rasshiren. Novyy razmer: %d\n", arr.size);
                break;
            }
            case 4:
                print_all(&arr);
                break;
            case 5:
                clear_array(&arr);
                break;
            case 0:
                printf("Zavershenie programmy...\n");
                break;
            default:
                printf("Nevernyy vybor. Poprobuite snova.\n");
        }
    } while (choice != 0);

    /* Osvobozhdaem pamyat pered zaversheniem */
    clear_array(&arr);
    return 0;
}
